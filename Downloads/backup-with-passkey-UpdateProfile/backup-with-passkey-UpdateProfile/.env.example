# Configuración del Servidor Principal
PORT=3001

# Configuración SMTP para envío de emails
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=tu_password_smtp_aqui

# Configuración de Email
EMAIL_FROM_NAME="Sistema de Votaciones"
EMAIL_FROM_ADDRESS="noreply@tu-dominio.com"
SUPERADMIN_EMAIL=admin@tu-dominio.com

# Configuración de MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=sistema_votaciones_etica

# Backend Server Configuration
BACKEND_PORT=3002

# Configuración avanzada de MongoDB
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT=5000

# Configuración de Desarrollo
NODE_ENV=development
VITE_API_URL=http://localhost:3001

# API Keys (opcional)
GEMINI_API_KEY=tu_api_key_opcional_aqui
